<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- LogstashEncoder menyertakan MDC secara default; field dt.trace_id/dt.span_id
             yang di-inject Dynatrace OneAgent akan muncul otomatis tanpa kode korelasi. -->
        <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
    </appender>
    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>
</configuration>
