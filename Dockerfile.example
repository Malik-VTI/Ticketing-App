# ─────────────────────────────────────────────────────────────
# Stage 1: Builder
# Build a dynamically linked binary for Dynatrace OneAgent
# auto-injection support (requires external linker + libc).
# Reference: https://docs.dynatrace.com/docs/shortlink/go-known-limitations
# ─────────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS builder

# Install gcc and musl-dev required for CGO + external linker (Alpine uses musl, not glibc)
RUN apk add --no-cache gcc musl-dev

WORKDIR /app

# Cache dependencies first (avoids re-downloading on every build)
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build a dynamically linked binary:
#   CGO_ENABLED=1     → enables cgo (required for external linking)
#   -linkmode=external → forces use of the system (musl) linker
#                        so that libc is correctly initialized at runtime,
#                        which is what Dynatrace OneAgent requires.
RUN CGO_ENABLED=1 GOOS=linux go build \
      -ldflags="-linkmode=external" \
      -o beego-app \
      main.go

# ─────────────────────────────────────────────────────────────
# Stage 2: Final image
# Alpine provides musl libc — required by Dynatrace OneAgent.
# ─────────────────────────────────────────────────────────────
FROM alpine:3.19

WORKDIR /app

# ca-certificates → needed for HTTPS (Swagger CDN)
# libc6-compat    → compatibility shim for dynamically linked Go binaries on Alpine/musl
# tzdata          → timezone support
RUN apk add --no-cache ca-certificates libc6-compat tzdata

# Copy the dynamically linked binary from builder
COPY --from=builder /app/beego-app .

# Copy runtime assets
COPY --from=builder /app/conf ./conf
COPY --from=builder /app/swagger ./swagger

EXPOSE 8080

# Run via /bin/sh so Dynatrace OneAgent's parent-process injection
# is satisfied (the parent process is dynamically linked /bin/sh)
CMD ["/bin/sh", "-c", "./beego-app"]
